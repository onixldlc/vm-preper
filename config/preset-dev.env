# preset-dev.env — full dev environment preset
# Usage: source this file (or let install-preset.sh load it) before running install-tools.sh
#
# INSTALL_LANGS       — comma-separated: 1=go 2=node 3=python 4=rust
# INSTALL_CONTAINERS  — comma-separated: 1=docker 2=podman
# INSTALL_NETWORKS    — comma-separated: 1=nslookup/dig 2=ip 3=ping 4=traceroute
#                       5=iperf3 6=mtr 7=nmap 8=tcpdump 9=wireshark 10=net-tools 11=telnet
# INSTALL_MISC        — comma-separated: 1=btop 2=ytop 3=lazygit 4=lazydocker
#                       5=neofetch 6=rsync 7=neovim
# BTOP_ROOT_THEME     — Y/n: symlink btop catppuccin theme for root
# NVCHAD              — Y/n: clone nvchad config for current user
# NVCHAD_ROOT         — Y/n: symlink nvchad config to root (requires NVCHAD=Y)
# CLEAR_HISTORY       — Y/n: wipe bash history at the end

INSTALL_DEPS=Y
INSTALL_LANGS=1,2,3,4
INSTALL_CONTAINERS=1
# WARNING: changing network config can disconnect you from a remote server
INSTALL_NETWORKS=1,2,3,4,6,8,10,11
INSTALL_MISC=1,2,4,5,6,7
CLEAR_HISTORY=N
BTOP_ROOT_THEME=Y
NVCHAD=Y
NVCHAD_ROOT=Y
