# preset-dev.env — full dev environment preset
# Usage: source this file (or let install-preset.sh load it) before running install-tools.sh
#
# INSTALL_LANGS       — comma-separated names: go, node, python, rust
# INSTALL_CONTAINERS  — comma-separated names: docker, podman
# INSTALL_NETWORKS    — comma-separated names: nslookup/dig, ip, ping, traceroute,
#                       iperf3, mtr, nmap, tcpdump, wireshark, net-tools, telnet
# INSTALL_MISC        — comma-separated names: btop, bottom/btm, lazygit, lazydocker,
#                       neofetch, rsync, neovim/nvim
# BTOP_ROOT_THEME     — Y/n: symlink btop catppuccin theme for root
# NVCHAD              — Y/n: clone nvchad config for current user
# NVCHAD_ROOT         — Y/n: symlink nvchad config to root (requires NVCHAD=Y)
# CLEAR_HISTORY       — Y/n: wipe bash history at the end

INSTALL_DEPS=Y
INSTALL_LANGS=go,node,python,rust
INSTALL_CONTAINERS=docker
# WARNING: these are diagnostic tools only — safe over SSH, won't change network config
INSTALL_NETWORKS=nslookup,ip,ping,traceroute,mtr,tcpdump,net-tools,telnet
INSTALL_MISC=btop,bottom,lazydocker,neofetch,rsync,neovim
CLEAR_HISTORY=N
BTOP_ROOT_THEME=Y
NVCHAD=Y
NVCHAD_ROOT=Y
